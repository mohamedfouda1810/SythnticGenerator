# ══════════════════════════════════════
# DATABASE
# ══════════════════════════════════════

DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/fast_db

# 
# Setup steps for PostgreSQL:
# 1. Install PostgreSQL and start the service
# 2. Open psql or pgAdmin and run:
#    CREATE DATABASE synthgen;
#    CREATE USER synthgen_user WITH PASSWORD 'yourpassword';
#    GRANT ALL PRIVILEGES ON DATABASE synthgen TO synthgen_user;
# 3. Update DATABASE_URL above with your credentials

# ══════════════════════════════════════
# AUTH
# ══════════════════════════════════════
SECRET_KEY=synthgen-secret-change-this-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# ══════════════════════════════════════
# APP SETTINGS
# ══════════════════════════════════════
MAX_FILE_SIZE_MB=10
MAX_ROWS=50000
DEFAULT_EPOCHS=100
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ══════════════════════════════════════
# EMAIL (Optional - for production)
# ══════════════════════════════════════
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_FROM=your-email@gmail.com
# MAIL_PORT=587
# MAIL_SERVER=smtp.gmail.com
